DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skillshub

OPENAI_API_KEY=sk-...

# ── Storage ──────────────────────────────────────────────────────────────────
# Local development (MinIO via docker-compose)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=resumes
STORAGE_FORCE_PATH_STYLE=true

# Production (Cloudflare R2) — replace the block above with:
# STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY=<r2-access-key-id>
# STORAGE_SECRET_KEY=<r2-secret-access-key>
# STORAGE_BUCKET=resumes
# STORAGE_FORCE_PATH_STYLE=false

BETTER_AUTH_SECRET=change-me-in-production
PORT=3001
